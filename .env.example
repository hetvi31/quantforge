# ==========================================
# QuantForge Environment Configuration Example
# ==========================================

# PostgreSQL Config
POSTGRES_DB=quantforge
POSTGRES_USER=postgres
POSTGRES_PASSWORD=securepassword
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis Config
REDIS_HOST=redis
REDIS_PORT=6379

# API Gateway Config
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000

# Market Feed Handler & Matching Engine Configuration
FEED_HOST=localhost
FEED_TCP_PORT=9001
FEED_UDP_PORT=9002

# AI Services API Keys (Provide actual keys in .env)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# System Performance Metrics Exporter
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
