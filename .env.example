# ==========================================
# QuantForge environment configuration
# Copy to .env and adjust. Never commit real secrets.
# ==========================================

# PostgreSQL
POSTGRES_DB=quantforge
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Matching engine (TCP) + feed handler (UDP)
FEED_HOST=matching-engine
FEED_TCP_PORT=9001
FEED_UDP_PORT=9002

# API gateway
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000
# MUST CHANGE before any non-local deployment. Shared secret required on all
# write/admin endpoints (X-API-Key header) and the AI research service.
API_KEY=change-me-api-key
# Comma-separated allowed browser origins for CORS.
CORS_ORIGINS=http://localhost:3001

# AI research service (sentiment LLM; falls back to a heuristic if unset)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Observability
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_PASSWORD=change-me-grafana

# Terminal build-time config (Vite). Used when building the terminal image.
# VITE_API_KEY MUST match API_KEY above — no default fallback in the JS bundle.
VITE_API_BASE=http://localhost:8000
VITE_AI_BASE=http://localhost:8001
VITE_API_KEY=change-me-api-key
